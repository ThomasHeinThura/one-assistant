# Copy to .env for local dev. NEVER commit a real .env.
# In Azure these are Container Apps secrets / Key Vault references (see deploy/azure).

ENV=dev
LOG_LEVEL=INFO

# --- datastores (compose service names) ---
DATABASE_URL=postgresql://maria:maria@db:5432/maria
REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=maria_rag
EMBEDDING_DIM=768
CLOUD_EMBEDDINGS=false          # Tier-1 must stay on-device/self-hosted; keep false

# --- message bus / store ---
# redis_streams (default, MVP) | kafka (scale phase: --profile kafka + aiokafka)
BUS_BACKEND=redis_streams
BUS_STREAM=maria.events
BUS_GROUP=maria.workers
KAFKA_BOOTSTRAP=                # e.g. kafka:9092 when BUS_BACKEND=kafka

# --- API auth (mobile bearer token) ---
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
# Leave blank in dev to allow through; REQUIRED in staging/prod.
API_TOKEN=

# Exact origins only. Never "*" in prod.
CORS_ORIGINS=["http://localhost:5173"]

# --- Ollama Cloud (Tier 2/3 cloud LLM ONLY; Tier 1 stays on-device) ---
# Key format: <id>.<secret>. gemma4:31b is free; deepseek-* need a paid plan.
OLLAMA_API_KEY=
OLLAMA_BASE_URL=https://ollama.com/v1
OLLAMA_MODELS=["gemma4:31b"]

# --- Plane (service token, not interactive MCP) ---
PLANE_BASE_URL=
PLANE_API_KEY=
PLANE_WORKSPACE_SLUG=

# --- Notion (internal-integration token) ---
NOTION_TOKEN=

# --- Langfuse (tracing) — NOT run locally ---
# Use Langfuse Cloud (https://cloud.langfuse.com) or a dedicated VM. Leave the
# keys blank and tracing is a no-op; fill them to enable tracing.
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# --- Postgres container bootstrap (compose only) ---
POSTGRES_USER=maria
POSTGRES_PASSWORD=maria
POSTGRES_DB=maria
