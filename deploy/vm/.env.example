# Edge stack config (deploy/vm). Copy to .env on the VM.
# Base domain — services are served at <service>.${DOMAIN}
DOMAIN=technexus.info
# Let's Encrypt registration email (expiry/security notices)
ACME_EMAIL=thomas.h.thura@bimgoc.com
# Cloudflare API token for DNS-01 (scoped: Zone.DNS:Edit + Zone:Read on technexus.info)
CF_DNS_API_TOKEN=
